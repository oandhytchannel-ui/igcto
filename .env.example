# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The API URL for your Supabase project.
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: The secret service role key for bypassing RLS rules and permission restrictions.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# SUPABASE_SCHEMA: The specific PostgreSQL schema to isolate the AI memory tables within the database.
SUPABASE_SCHEMA="studyig_cto"

# TELEGRAM_BOT_TOKEN: The token received from @BotFather for your Telegram bot.
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# ADMIN_SECRET: High-entropy secret key protecting the admin endpoints (e.g. /api/admin/register-webhook) from public execution on Vercel.
ADMIN_SECRET="your-high-entropy-admin-secret"

# GITHUB_TOKEN: A personal access token to parse and analyze repository files.
GITHUB_TOKEN="your-github-personal-access-token"

# GITHUB_OWNER: The GitHub organization or user account owning the target repository.
GITHUB_OWNER="your-github-owner"

# GITHUB_REPO: The specific repository name to index and analyze.
GITHUB_REPO="your-github-repo"

# StudyIG Production Database (Read-only Inspection)
STUDYIG_SUPABASE_URL="https://your-studyig-production-project.supabase.co"
STUDYIG_SUPABASE_SERVICE_ROLE_KEY="your-studyig-production-service-role-key"

